# ==============================
# Comment Settings
# ==============================
GRACEFUL_SHUTDOWN_PERIOD=30s

# ==============================
# Global Log Settings
# ==============================
LOG_LEVEL=debug

# ==============================
# Metric Server Host
# ==============================
METRIC_SERVER_HOST=0.0.0.0
METRIC_SERVER_PORT=9492
METRIC_SERVER_READ_TIMEOUT=30S
METRIC_SERVER_WRITE_TIMEOUT=30S

# ==============================
# HTTP Server Settings
# ==============================
HTTP_SERVER_HOST=0.0.0.0
HTTP_SERVER_PORT=9490
HTTP_SERVER_READ_TIMEOUT=30s
HTTP_SERVER_WRITE_TIMEOUT=30s
HTTP_ENABLE_CORS=true
HTTP_BODY_LIMIT=100k
HTTP_REQURIE_REQUEST_ID=true

# ==============================
# Postgres Configuation
# ==============================
POSTGRES_URL=postgresql://postgres:password@0.0.0.0:5432/gaian-admin-backend?sslmode=disable
PORTGRES_MAX_CONNECTION=2
POSTGRES_MIN_CONNECTION=1
POSTGRES_MAX_CONNECTION_IDLE_TIME=4m
POSTGRES_PING_TIMEOUT=30s
POSTGRES_LOG_LEVEL=trace
