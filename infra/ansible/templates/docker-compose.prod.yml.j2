services:
  postgres:
    image: postgres:16-alpine
    container_name: digital_project_postgres
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: {{ postgres_password }}
      POSTGRES_DB: digital_db
      PGDATA: /var/lib/postgresql/data
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - gaian
    healthcheck:
      test: ['CMD-SHELL', 'pg_isready -U postgres']
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 30s
    restart: unless-stopped

  valkey:
    image: valkey/valkey:8.1.4-alpine3.22
    container_name: digital_valkey
    command: --requirepass {{ valkey_password }}
    volumes:
      - valkey_data:/data
    networks:
      - gaian
    restart: unless-stopped

volumes:
  postgres_data:
  valkey_data:

networks:
  gaian:
    name: gaian
